###WSD using supervised learning (Naive Bayes)
from sklearn.feature_extraction.text import CountVectorizer
from sklearn.naive_bayes import MultinomialNB

# Step 1: Training Data (manually labeled)
# bank = 0 (financial), bank = 1 (river)
sentences = [
    "I deposited money in the bank",
    "She works at the bank",
    "He opened a bank account",
    "The river bank is beautiful",
    "They sat near the bank of the river",
    "The bank was full of sand"
]

labels = [0, 0, 0, 1, 1, 1]  # correct senses

# Step 2: Convert text to numbers (feature extraction)
vectorizer = CountVectorizer()
X = vectorizer.fit_transform(sentences)

# Step 3: Train model
model = MultinomialNB()
model.fit(X, labels)

# Step 4: Test sentence
test_sentence = ["He sat on the bank of the river"]

# Convert test sentence
X_test = vectorizer.transform(test_sentence)

# Step 5: Predict sense
prediction = model.predict(X_test)

# Step 6: Output
if prediction[0] == 0:
    print("Sense: Financial Bank")
else:
    print("Sense: River Bank")
