##Sentece boundary
from sklearn.feature_extraction.text import CountVectorizer
from sklearn.linear_model import LogisticRegression

# Step 1: Training data (simple examples)
train_text = [
    "Mr.", "Dr.", "etc.",
    "He went home.", "She is happy.", "They are playing."
]

# Labels: 0 = not sentence end, 1 = sentence end
labels = [0, 0, 0, 1, 1, 1]

# Step 2: Convert to numeric
vectorizer = CountVectorizer()
X = vectorizer.fit_transform(train_text)

# Step 3: Train model
model = LogisticRegression()
model.fit(X, labels)

# Step 4: Take dynamic input
test = input("Enter text: ")

# Step 5: Predict
X_test = vectorizer.transform([test])

prediction = model.predict(X_test)[0]

# Step 6: Output
if prediction == 1:
    print("It is a Sentence Boundary")
else:
    print("Not a Sentence Boundary")
