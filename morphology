# Morphological Analysis using Dictionary Lookup

# Step 1: Create a dictionary of root words
dictionary = {
    "play": "verb",
    "walk": "verb",
    "eat": "verb",
    "go": "verb",
    "read": "verb",
    "cat": "noun",
    "dog": "noun"
}

# Step 2: Define common suffixes
suffixes = ["ing", "ed", "s"]

# Step 3: Morphological analyzer function
def morphological_analysis(word):
    # Direct lookup
    if word in dictionary:
        return f"Root word found: {word} ({dictionary[word]})"
    
    # Try removing suffixes
    for suffix in suffixes:
        if word.endswith(suffix):
            root = word[:-len(suffix)]
            if root in dictionary:
                return f"Root word: {root} ({dictionary[root]}), Suffix: {suffix}"
    
    return "Word not found in dictionary"

# Step 4: Test words
word = input("Enter a word: ")

# Step 5: Analyze words
print(f"{word} -> {morphological_analysis(word)}")
