### porter stemmer
def porter_stem(word):
    suffixes = ['ing', 'ly', 'ed', 'ious', 'ies', 'ive', 'es', 's', 'ment']
    
    for suffix in suffixes:
        if word.endswith(suffix):
            return word[:-len(suffix)]
    
    return word

words = ["playing", "played", "happiness", "movement"]

for w in words:
    print(w, "->", porter_stem(w))
