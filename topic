###Token Boundary Detection

from sklearn.feature_extraction.text import CountVectorizer
from sklearn.linear_model import LogisticRegression

# Step 1: More realistic training data
sent_pairs = [
    "India won the cricket match The players celebrated their victory",
    "The team practiced hard before the tournament The coach was proud",
    
    "I love playing cricket The weather is very hot today",
    "She is cooking dinner The stock market is unstable"
]

# Labels: 0 = same topic, 1 = topic change
labels = [0, 0, 1, 1]

# Step 2: Convert text to numbers
vectorizer = CountVectorizer()
X = vectorizer.fit_transform(sent_pairs)

# Step 3: Train model
model = LogisticRegression()
model.fit(X, labels)

# Step 4: Dynamic input
text = input("Enter two sentences: ")

# Step 5: Predict
X_test = vectorizer.transform([text])
prediction = model.predict(X_test)[0]

# Step 6: Output
if prediction == 1:
    print("👉 Topic Changed")
else:
    print("👉 Same Topic")
