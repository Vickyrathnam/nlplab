### WSD - Lesk Algorithm
import nltk
from nltk.corpus import wordnet as wn

# download only wordnet (no punkt needed)
nltk.download('wordnet')

# Simple tokenization using split()
def simple_tokenize(text):
    return text.lower().split()

# Lesk Algorithm (simple version)
def lesk(sentence, word):
    context = set(simple_tokenize(sentence))
    
    best_sense = None
    max_overlap = 0
    
    for sense in wn.synsets(word):
        gloss = set(simple_tokenize(sense.definition()))
        
        overlap = len(context & gloss)
        
        if overlap > max_overlap:
            max_overlap = overlap
            best_sense = sense
    
    return best_sense

# Test
sentence = input("enter sentence:")
word =  input("enter word")

sense = lesk(sentence, word)

print("Sentence:", sentence)
print("Word:", word)
print("Best Sense:", sense.name())
print("Meaning:", sense.definition())
