import nltk
from nltk import pos_tag

# Download required model (run only once)
nltk.download('averaged_perceptron_tagger_eng')

def predicate_argument(sentence):
    words = sentence.lower().split()
    tagged = pos_tag(words)

    subject = ""
    predicate = ""
    obj = ""

    for word, tag in tagged:
        if tag.startswith('NN') and subject == "":
            subject = word
        elif tag.startswith('NNS'):
            predicate = word
        elif tag.startswith('VBP') and subject != "":
            obj = word

    return subject, predicate, obj

# Input
sentence = input("Enter a sentence: ")
s, p, o = predicate_argument(sentence)

print("\n--- Predicate Argument Structure ---")
print("Subject:", s)
print("Predicate:", p)
print("Object:", o)
